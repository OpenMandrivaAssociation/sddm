--- /dev/null
+++ b/src/helper/WaylandSocketWatcher.cpp
@@ -0,0 +1,91 @@
+/*
+ * Session process wrapper
+ * Copyright (C) 2015-2016 Pier Luigi Fiorini <pierluigi.fiorini@gmail.com>
+ * Copyright (C) 2014 Martin Bříza <mbriza@redhat.com>
